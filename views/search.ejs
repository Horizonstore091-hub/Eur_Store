<%- include('partials/header') %>
<section class="section" style="padding: 15px 0;">
  <div class="container">
    <h1 style="font-size: 1.3rem; font-weight: 400; margin-bottom: 8px;">Results for "<%= query %>"</h1>
    <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 16px;"><%= total %> result<%= total !== 1 ? 's' : '' %></p>
    <% if (products.length === 0) { %>
      <div style="text-align: center; padding: 40px;">
        <h3>No results found</h3>
        <p style="color: var(--text-secondary); margin: 6px 0 12px;">Try different keywords or browse our categories.</p>
        <a href="/products" class="btn btn-primary">Browse All Products</a>
      </div>
    <% } else { %>
      <div class="product-grid">
        <% products.forEach(p => { %>
          <div class="product-card">
            <a href="/products/<%= p.slug %>" class="image">
              <img src="<%= p.image || '/images/placeholder.svg' %>" alt="<%= p.name %>">
            </a>
            <div class="category"><%= p.category_name || '' %></div>
            <h3><a href="/products/<%= p.slug %>"><%= p.name %></a></h3>
            <div class="price">&euro;<%= p.price.toFixed(2) %></div>
            <div class="free-ship"><span class="icon-truck"></span> FREE delivery</div>
            <form action="/cart/add" method="POST" class="add-to-cart">
              <input type="hidden" name="product_id" value="<%= p.id %>">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="btn btn-primary btn-block">Add to Cart</button>
            </form>
          </div>
        <% }); %>
      </div>
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= i %>" class="<%= page === i ? 'active' : '' %>"><%= i %></a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
