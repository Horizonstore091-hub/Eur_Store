<%- include('partials/header') %>
<section class="section" style="padding: 2rem 0;">
  <div class="container">
    <h1 style="font-size: 1.5rem; margin-bottom: 1rem;">Search Results for "<%= query %>"</h1>
    <p style="color: var(--gray-500); margin-bottom: 1.5rem;"><%= total %> result<%= total !== 1 ? 's' : '' %> found</p>
    <% if (products.length === 0) { %>
      <div style="text-align: center; padding: 3rem;">
        <p style="font-size: 3rem;">🔍</p>
        <h3>No results found</h3>
        <p style="color: var(--gray-500);">Try different keywords or browse our categories.</p>
        <a href="/products" class="btn btn-primary" style="margin-top: 1rem;">Browse All Products</a>
      </div>
    <% } else { %>
      <div class="product-grid">
        <% products.forEach(p => { %>
          <div class="product-card">
            <a href="/products/<%= p.slug %>" class="image">
              <img src="<%= p.image || 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 200 200%22><rect fill=%22%23e5e7eb%22 width=%22200%22 height=%22200%22/><text x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 dy=%22.3em%22 font-size=%2240%22>❄️</text></svg>' %>" alt="<%= p.name %>">
            </a>
            <div class="info">
              <h3><a href="/products/<%= p.slug %>"><%= p.name %></a></h3>
              <div class="price">€<%= p.price.toFixed(2) %></div>
            </div>
          </div>
        <% }); %>
      </div>
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= i %>" class="<%= page === i ? 'active' : '' %>"><%= i %></a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
