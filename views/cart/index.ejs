<%- include('../partials/header') %>
<section class="container cart-page">
  <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Shopping Cart</h1>
  <% if (items.length === 0) { %>
    <div style="text-align: center; padding: 3rem;">
      <p style="font-size: 4rem; margin-bottom: 1rem;">🛒</p>
      <h3>Your cart is empty</h3>
      <p style="color: var(--gray-500); margin: 0.5rem 0 1.5rem;">Start shopping for cooling products!</p>
      <a href="/products" class="btn btn-primary btn-lg">Browse Products</a>
    </div>
  <% } else { %>
    <div style="overflow-x: auto;">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td>
                <div class="product-info">
                  <a href="/products/<%= item.slug %>">
                    <img src="<%= item.image || 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 80 80%22><rect fill=%22%23e5e7eb%22 width=%2280%22 height=%2280%22/><text x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 dy=%22.3em%22 font-size=%2220%22>❄️</text></svg>' %>" alt="<%= item.name %>">
                  </a>
                  <div>
                    <a href="/products/<%= item.slug %>" style="text-decoration: none; color: var(--gray-800); font-weight: 500;"><%= item.name %></a>
                    <div style="font-size: 0.8rem; color: var(--gray-500);">SKU: <%= item.sku || 'N/A' %></div>
                  </div>
                </div>
              </td>
              <td>€<%= item.price.toFixed(2) %></td>
              <td>
                <form action="/cart/update" method="POST" style="display: flex; align-items: center; gap: 0.3rem;">
                  <input type="hidden" name="product_id" value="<%= item.id %>">
                  <input type="number" name="quantity" value="<%= item.quantity %>" min="0" class="qty-input">
                  <button type="submit" class="btn btn-sm btn-outline">Update</button>
                </form>
              </td>
              <td><strong>€<%= (item.price * item.quantity).toFixed(2) %></strong></td>
              <td>
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="product_id" value="<%= item.id %>">
                  <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <div class="cart-summary">
      <% if (subtotal < freeThreshold) { %>
        <div class="free-shipping-progress">
          <div class="fill" style="width: <%= Math.min(100, (subtotal / freeThreshold) * 100) %>%"></div>
        </div>
        <p style="font-size: 0.85rem; color: var(--gray-500); text-align: center;">
          Add €<%= (freeThreshold - subtotal).toFixed(2) %> more for free shipping!
        </p>
      <% } else { %>
        <div class="free-shipping-notice">🎉 You've qualified for free shipping across Europe!</div>
      <% } %>
      <div class="row"><span>Subtotal</span><span>€<%= subtotal.toFixed(2) %></span></div>
      <div class="row"><span>Shipping</span><span><%= shippingFree ? 'FREE' : '€' + shippingCost.toFixed(2) %></span></div>
      <div class="row total"><span>Total</span><span>€<%= (subtotal + (shippingFree ? 0 : shippingCost)).toFixed(2) %></span></div>
      <a href="/checkout" class="btn btn-primary btn-lg" style="width: 100%; text-align: center; margin-top: 1rem;">Proceed to Checkout</a>
      <div style="text-align: center; margin-top: 0.5rem;">
        <a href="/products" style="color: var(--primary); font-size: 0.9rem;">Continue Shopping</a>
      </div>
    </div>
  <% } %>
</section>
<%- include('../partials/footer') %>
