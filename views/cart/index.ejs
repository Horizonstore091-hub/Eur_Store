<%- include('../partials/header') %>
<section class="container cart-page">
  <h1>Shopping Cart</h1>
  <% if (items.length === 0) { %>
    <div style="text-align: center; padding: 40px;">
      <h3>Your cart is empty</h3>
      <p style="color: var(--text-secondary); margin: 8px 0 16px;">Discover our range of cooling products.</p>
      <a href="/products" class="btn btn-primary btn-lg">Browse Products</a>
    </div>
  <% } else { %>
    <div style="overflow-x: auto;">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td>
                <div class="product-info">
                  <a href="/products/<%= item.slug %>">
                    <img src="<%= item.image || '/images/placeholder.svg' %>" alt="<%= item.name %>">
                  </a>
                  <div>
                    <a href="/products/<%= item.slug %>" style="text-decoration: none; color: var(--text); font-weight: 500;"><%= item.name %></a>
                    <div style="font-size: 12px; color: var(--text-secondary);">SKU: <%= item.sku || 'N/A' %></div>
                    <% if (item.energy_rating) { %><span class="energy-badge"><%= item.energy_rating %></span><% } %>
                  </div>
                </div>
              </td>
              <td>&euro;<%= item.price.toFixed(2) %></td>
              <td>
                <form action="/cart/update" method="POST" style="display: flex; align-items: center; gap: 6px;">
                  <input type="hidden" name="product_id" value="<%= item.id %>">
                  <input type="number" name="quantity" value="<%= item.quantity %>" min="0" style="width: 60px; padding: 6px; border: 1px solid var(--border); border-radius: 4px;">
                  <button type="submit" class="btn btn-sm btn-secondary">Update</button>
                </form>
              </td>
              <td><strong>&euro;<%= (item.price * item.quantity).toFixed(2) %></strong></td>
              <td>
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="product_id" value="<%= item.id %>">
                  <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <div class="cart-summary">
      <% if (subtotal < freeThreshold) { %>
        <div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 6px;">
          Add <strong>&euro;<%= (freeThreshold - subtotal).toFixed(2) %></strong> more for free delivery
        </div>
        <div class="free-shipping-progress">
          <div class="fill" style="width: <%= Math.min(100, (subtotal / freeThreshold) * 100) %>%"></div>
        </div>
      <% } else { %>
        <div class="free-shipping-bar"><span class="icon-truck"></span> You qualify for free delivery across Europe!</div>
      <% } %>
      <div class="row"><span>Subtotal</span><span>&euro;<%= subtotal.toFixed(2) %></span></div>
      <div class="row"><span>Delivery</span><span><%= shippingFree ? 'FREE' : '&euro;' + shippingCost.toFixed(2) %></span></div>
      <div class="row total"><span>Total</span><span>&euro;<%= (subtotal + (shippingFree ? 0 : shippingCost)).toFixed(2) %></span></div>
      <a href="/checkout" class="btn btn-primary btn-lg btn-block" style="margin-top: 10px;">Proceed to Checkout</a>
      <div style="text-align: center; margin-top: 6px;">
        <a href="/products" style="color: var(--link); font-size: 13px;">Continue Shopping</a>
      </div>
    </div>
  <% } %>
</section>
<%- include('../partials/footer') %>
