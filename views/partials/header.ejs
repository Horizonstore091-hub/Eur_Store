<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= locals.siteName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:;base64,iVBORw0KGgo=">
  <meta name="theme-color" content="#131921">
</head>
<body>
<div class="top-banner">
  <div class="container">
    Free shipping across Europe on orders over &euro;99 &mdash; <a href="/products">Shop now</a>
  </div>
</div>
<header>
  <div class="container header-main">
    <a href="/" class="logo">Euro<span class="dot">Cool</span></a>
    <form action="/search" method="GET" class="header-search">
      <input type="text" name="q" placeholder="Search cooling products..." required>
      <button type="submit"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></button>
    </form>
    <div class="header-links">
      <% if (user) { %>
        <a href="/auth/account"><span>Hello, <%= user.first_name %></span><strong>Account</strong></a>
        <a href="/auth/logout"><span>&nbsp;</span><strong>Logout</strong></a>
      <% } else { %>
        <a href="/auth/login"><span>Hello, Sign in</span><strong>Account</strong></a>
      <% } %>
      <a href="/cart" class="cart-link">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <% if (locals.cartCount > 0) { %><span class="count"><%= cartCount %></span><% } %>
      </a>
    </div>
  </div>
</header>
<nav>
  <div class="container">
    <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
    <a href="/products" class="<%= currentPath.startsWith('/products') ? 'active' : '' %>">All Products</a>
    <% (typeof categories !== 'undefined' ? categories : []).slice(0, 8).forEach(c => { %>
      <a href="/products?category=<%= c.slug %>" class="<%= currentPath.includes(c.slug) ? 'active' : '' %>"><%= c.name %></a>
    <% }); %>
  </div>
</nav>
<main>
