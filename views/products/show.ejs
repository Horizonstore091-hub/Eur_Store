<%- include('../partials/header') %>
<section class="container">
  <div style="padding: 1rem 0; font-size: 0.9rem; color: var(--gray-500);">
    <a href="/" style="color: var(--primary);">Home</a> / <a href="/products" style="color: var(--primary);">Products</a> / <%= product.category_name ? '<a href="/products?category=' + product.category_slug + '" style="color: var(--primary);">' + product.category_name + '</a> / ' : '' %><%= product.name %>
  </div>

  <div class="product-detail">
    <div class="gallery">
      <div class="main-image" id="mainImage">
        <img src="<%= product.image || 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 400 400%22><rect fill=%22%23e5e7eb%22 width=%22400%22 height=%22400%22/><text x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 dy=%22.3em%22 font-size=%2260%22>❄️</text></svg>' %>" alt="<%= product.name %>" id="previewImage">
      </div>
      <% if (images.length > 0) { %>
        <div class="thumbnails">
          <% images.forEach((img, i) => { %>
            <img src="<%= img %>" alt="<%= product.name %>" onclick="document.getElementById('previewImage').src=this.src">
          <% }); %>
        </div>
      <% } %>
    </div>

    <div>
      <h1><%= product.name %></h1>
      <div class="meta">
        <% if (product.brand) { %>Brand: <strong><%= product.brand %></strong> |<% } %>
        SKU: <%= product.sku || 'N/A' %>
        <% if (avgRating && avgRating.count > 0) { %> | ★ <%= Number(avgRating.avg).toFixed(1) %> (<%= avgRating.count %> review<%= avgRating.count !== 1 ? 's' : '' %>)<% } %>
      </div>
      <% if (product.short_description) { %><p style="color: var(--gray-600); margin-bottom: 1rem;"><%= product.short_description %></p><% } %>
      <div class="price-row">
        €<%= product.price.toFixed(2) %>
        <% if (product.compare_price && product.compare_price > product.price) { %><span class="compare-price">€<%= product.compare_price.toFixed(2) %></span><span style="font-size: 0.9rem; color: var(--secondary); font-weight: 600; margin-left: 0.5rem;">Save €<%= (product.compare_price - product.price).toFixed(2) %></span><% } %>
      </div>

      <div style="display: flex; gap: 1rem; margin-bottom: 1rem; font-size: 0.85rem;">
        <% if (product.energy_rating) { %><span>⚡ Energy: <strong><%= product.energy_rating %></strong></span><% } %>
        <% if (product.noise_level) { %><span>🔊 Noise: <strong><%= product.noise_level %></strong></span><% } %>
        <% if (product.coverage_area) { %><span>📐 Covers: <strong><%= product.coverage_area %></strong></span><% } %>
        <% if (product.power_consumption) { %><span>💡 Power: <strong><%= product.power_consumption %></strong></span><% } %>
      </div>

      <% if (features.length > 0) { %>
        <h3 style="font-size: 1rem; margin: 1rem 0 0.5rem;">Key Features</h3>
        <ul class="features-list">
          <% features.forEach(f => { %><li><%= f %></li><% }); %>
        </ul>
      <% } %>

      <div class="specs">
        <% if (product.weight) { %><dt>Weight</dt><dd><%= product.weight %> kg</dd><% } %>
        <% if (product.dimensions) { %><dt>Dimensions</dt><dd><%= product.dimensions %></dd><% } %>
      </div>

      <div style="color: var(--gray-600); font-size: 0.85rem; margin: 1rem 0;">
        <% if (product.stock > 10) { %>✅ In Stock<% } else if (product.stock > 0) { %>⚠️ Only <%= product.stock %> left<% } else { %>❌ Out of Stock<% } %>
        | 📦 Free shipping across Europe | 🔒 Secure payment
      </div>

      <form action="/cart/add" method="POST">
        <input type="hidden" name="product_id" value="<%= product.id %>">
        <div class="qty-selector">
          <label>Quantity:</label>
          <input type="number" name="quantity" value="1" min="1" max="<%= product.stock || 99 %>">
        </div>
        <button type="submit" class="btn btn-primary btn-lg add-to-cart-btn" <%= product.stock === 0 ? 'disabled' : '' %>>Add to Cart — €<%= product.price.toFixed(2) %></button>
      </form>
    </div>
  </div>

  <div style="margin: 2rem 0;">
    <h3 style="margin-bottom: 1rem;">Description</h3>
    <div style="line-height: 1.8; color: var(--gray-600);"><%= product.description ? product.description.replace(/\n/g, '<br>') : 'No description available.' %></div>
  </div>

  <% if (related.length > 0) { %>
    <section style="margin: 3rem 0;">
      <h3 style="margin-bottom: 1rem;">Related Products</h3>
      <div class="product-grid">
        <% related.forEach(p => { %>
          <div class="product-card">
            <a href="/products/<%= p.slug %>" class="image">
              <img src="<%= p.image || 'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 200 200%22><rect fill=%22%23e5e7eb%22 width=%22200%22 height=%22200%22/><text x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 dy=%22.3em%22 font-size=%2240%22>❄️</text></svg>' %>" alt="<%= p.name %>">
            </a>
            <div class="info">
              <h3><a href="/products/<%= p.slug %>"><%= p.name %></a></h3>
              <div class="price">€<%= p.price.toFixed(2) %></div>
            </div>
          </div>
        <% }); %>
      </div>
    </section>
  <% } %>

  <section id="reviews" style="margin: 3rem 0;">
    <h3 style="margin-bottom: 1rem;">Customer Reviews</h3>
    <% if (avgRating && avgRating.count > 0) { %>
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <span style="font-size: 2.5rem; font-weight: 700; color: var(--gray-800);"><%= Number(avgRating.avg).toFixed(1) %></span>
        <div>
          <div style="font-size: 1.5rem; color: var(--accent);"><% for(let i=0; i<5; i++) { %><%= i < Math.round(avgRating.avg) ? '★' : '☆' %><% } %></div>
          <span style="color: var(--gray-500);"><%= avgRating.count %> review<%= avgRating.count !== 1 ? 's' : '' %></span>
        </div>
      </div>
    <% } %>
    <% reviews.forEach(r => { %>
      <div style="border: 1px solid var(--gray-200); border-radius: 8px; padding: 1rem; margin-bottom: 1rem;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <strong><%= r.first_name || 'Anonymous' %></strong>
          <span style="color: var(--accent);"><% for(let i=0; i<5; i++) { %><%= i < r.rating ? '★' : '☆' %><% } %></span>
        </div>
        <% if (r.title) { %><h4 style="margin: 0.3rem 0;"><%= r.title %></h4><% } %>
        <p style="font-size: 0.9rem; color: var(--gray-600);"><%= r.comment %></p>
        <small style="color: var(--gray-400);"><%= new Date(r.created_at).toLocaleDateString() %></small>
      </div>
    <% }); %>
    <% if (reviews.length === 0) { %><p style="color: var(--gray-500);">No reviews yet.</p><% } %>

    <% if (user) { %>
      <div style="margin-top: 2rem; border: 1px solid var(--gray-200); border-radius: 10px; padding: 1.5rem;">
        <h4>Write a Review</h4>
        <form action="/products/<%= product.id %>/review" method="POST">
          <input type="hidden" name="slug" value="<%= product.slug %>">
          <div style="margin: 0.5rem 0;">
            <label>Rating:</label>
            <select name="rating" style="padding: 0.4rem; border: 1px solid var(--gray-300); border-radius: 4px;">
              <option value="5">★★★★★</option>
              <option value="4">★★★★☆</option>
              <option value="3">★★★☆☆</option>
              <option value="2">★★☆☆☆</option>
              <option value="1">★☆☆☆☆</option>
            </select>
          </div>
          <div style="margin: 0.5rem 0;">
            <input type="text" name="title" placeholder="Review title" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
          </div>
          <div style="margin: 0.5rem 0;">
            <textarea name="comment" placeholder="Write your review..." style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px; min-height: 80px;"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Submit Review</button>
        </form>
      </div>
    <% } else { %>
      <p style="margin-top: 1rem;"><a href="/auth/login" style="color: var(--primary);">Login</a> to write a review.</p>
    <% } %>
  </section>
</section>
<%- include('../partials/footer') %>
