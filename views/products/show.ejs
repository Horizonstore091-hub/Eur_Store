<%- include('../partials/header') %>
<section class="container">
  <div class="breadcrumb">
    <a href="/">Home</a> / <a href="/products">Products</a> / <%= product.category_name ? '<a href="/products?category=' + product.category_slug + '">' + product.category_name + '</a> / ' : '' %><%= product.name %>
  </div>

  <div class="product-detail">
    <div class="gallery">
      <div class="main-image">
        <img src="<%= product.image || '/images/placeholder.svg' %>" alt="<%= product.name %>">
      </div>
    </div>

    <div>
      <h1><%= product.name %></h1>
      <div class="meta">
        <% if (product.brand) { %>Brand: <strong><%= product.brand %></strong> |<% } %>
        SKU: <%= product.sku || 'N/A' %>
        <% if (avgRating && avgRating.count > 0) { %> | <span style="color: var(--rating);"><%= Number(avgRating.avg).toFixed(1) %> stars</span> (<%= avgRating.count %> review<%= avgRating.count !== 1 ? 's' : '' %>)<% } %>
      </div>
      <% if (product.short_description) { %><p style="color: var(--text-secondary); margin: 8px 0;"><%= product.short_description %></p><% } %>

      <div class="price-row">
        <span class="symbol">&euro;</span><%= Math.floor(product.price) %><span class="cents">.<%= (product.price % 1).toFixed(2).slice(2) %></span>
        <% if (product.compare_price && product.compare_price > product.price) { %>
          <span class="compare-price">&euro;<%= product.compare_price.toFixed(2) %></span>
          <span class="save-amount">Save &euro;<%= (product.compare_price - product.price).toFixed(2) %></span>
        <% } %>
      </div>

      <div style="margin: 8px 0;">
        <% if (product.energy_rating) { %><span class="energy-badge"><%= product.energy_rating %></span> <% } %>
        <span style="font-size: 12px; color: var(--success);">Amazon's Choice</span>
      </div>

      <% if (features.length > 0) { %>
        <h3 style="font-size: 14px; font-weight: 700; margin: 12px 0 6px;">Key Features</h3>
        <ul class="features-list">
          <% features.forEach(f => { %><li><%= f %></li><% }); %>
        </ul>
      <% } %>

      <dl class="specs">
        <% if (product.weight) { %><dt>Weight</dt><dd><%= product.weight %> kg</dd><% } %>
        <% if (product.dimensions) { %><dt>Dimensions</dt><dd><%= product.dimensions %></dd><% } %>
        <% if (product.energy_rating) { %><dt>Energy Rating</dt><dd><%= product.energy_rating %></dd><% } %>
        <% if (product.noise_level) { %><dt>Noise Level</dt><dd><%= product.noise_level %></dd><% } %>
        <% if (product.coverage_area) { %><dt>Coverage</dt><dd><%= product.coverage_area %></dd><% } %>
        <% if (product.power_consumption) { %><dt>Power</dt><dd><%= product.power_consumption %></dd><% } %>
      </dl>

      <div class="buy-box">
        <div class="price">&euro;<%= product.price.toFixed(2) %></div>
        <div style="font-size: 12px; color: var(--text-secondary); margin: 4px 0;">All prices include VAT</div>
        <div style="color: var(--success); font-size: 13px; font-weight: 700; margin: 6px 0;">
          <% if (product.stock > 10) { %>In Stock<% } else if (product.stock > 0) { %>Only <%= product.stock %> left in stock<% } else { %>Out of Stock<% } %>
        </div>
        <div style="font-size: 12px; color: var(--success); margin-bottom: 8px;">FREE delivery across Europe</div>
        <form action="/cart/add" method="POST">
          <input type="hidden" name="product_id" value="<%= product.id %>">
          <div class="qty-selector">
            <label>Quantity:</label>
            <select name="quantity">
              <% for (let i = 1; i <= Math.min(product.stock || 1, 10); i++) { %>
                <option value="<%= i %>"><%= i %></option>
              <% } %>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-lg btn-block" <%= product.stock === 0 ? 'disabled' : '' %>>Add to Cart</button>
        </form>
        <div style="margin-top: 8px;">
          <a href="/checkout" class="btn btn-accent btn-lg btn-block" <%= product.stock === 0 ? 'disabled' : '' %>>Buy Now</a>
        </div>
        <div style="font-size: 11px; color: var(--text-secondary); text-align: center; margin-top: 8px;">
          Secure transaction &bull; 30-day returns
        </div>
      </div>
    </div>
  </div>

  <% if (product.description) { %>
  <div class="description-block">
    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 10px;">Product Description</h3>
    <div><%= product.description.replace(/\n/g, '<br>') %></div>
  </div>
  <% } %>

  <% if (related.length > 0) { %>
  <section style="margin: 30px 0;">
    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 12px;">Related Products</h3>
    <div class="product-grid">
      <% related.forEach(p => { %>
        <div class="product-card">
          <a href="/products/<%= p.slug %>" class="image">
            <img src="<%= p.image || '/images/placeholder.svg' %>" alt="<%= p.name %>">
          </a>
          <div class="category"><%= p.category_name || '' %></div>
          <h3><a href="/products/<%= p.slug %>"><%= p.name %></a></h3>
          <div class="price">&euro;<%= p.price.toFixed(2) %></div>
        </div>
      <% }); %>
    </div>
  </section>
  <% } %>

  <section id="reviews" style="margin: 30px 0;">
    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 12px;">Customer Reviews</h3>
    <% if (avgRating && avgRating.count > 0) { %>
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px; background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 16px;">
        <span style="font-size: 2rem; font-weight: 700; color: var(--text);"><%= Number(avgRating.avg).toFixed(1) %></span>
        <div>
          <div style="font-size: 1.2rem; color: var(--rating);"><% for(let i=0; i<5; i++) { %><%= i < Math.round(avgRating.avg) ? '\u2605' : '\u2606' %><% } %></div>
          <span style="color: var(--text-secondary); font-size: 13px;"><%= avgRating.count %> review<%= avgRating.count !== 1 ? 's' : '' %></span>
        </div>
      </div>
    <% } %>
    <% reviews.forEach(r => { %>
      <div style="background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 14px; margin-bottom: 10px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
          <strong><%= r.first_name || 'Anonymous' %></strong>
          <span style="color: var(--rating); font-size: 14px;"><% for(let i=0; i<5; i++) { %><%= i < r.rating ? '\u2605' : '\u2606' %><% } %></span>
        </div>
        <% if (r.title) { %><h4 style="margin: 4px 0; font-size: 14px;"><%= r.title %></h4><% } %>
        <p style="font-size: 13px; color: var(--text);"><%= r.comment %></p>
        <small style="color: var(--text-secondary);"><%= new Date(r.created_at).toLocaleDateString() %></small>
      </div>
    <% }); %>
    <% if (reviews.length === 0) { %><p style="color: var(--text-secondary);">No reviews yet.</p><% } %>

    <% if (user) { %>
      <div style="margin-top: 16px; background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 16px;">
        <h4 style="font-size: 14px; font-weight: 700; margin-bottom: 8px;">Write a Review</h4>
        <form action="/products/<%= product.id %>/review" method="POST">
          <input type="hidden" name="slug" value="<%= product.slug %>">
          <div style="margin: 6px 0;">
            <label style="font-size: 13px; font-weight: 600;">Rating:</label>
            <select name="rating" style="padding: 6px; border: 1px solid var(--border); border-radius: 4px;">
              <option value="5">5 stars</option>
              <option value="4">4 stars</option>
              <option value="3">3 stars</option>
              <option value="2">2 stars</option>
              <option value="1">1 star</option>
            </select>
          </div>
          <div style="margin: 6px 0;">
            <input type="text" name="title" placeholder="Review title" style="width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; font-size: 13px;">
          </div>
          <div style="margin: 6px 0;">
            <textarea name="comment" placeholder="Write your review..." style="width: 100%; padding: 8px; border: 1px solid var(--border); border-radius: 4px; min-height: 80px; font-size: 13px;"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Submit Review</button>
        </form>
      </div>
    <% } else { %>
      <p style="margin-top: 12px;"><a href="/auth/login">Login</a> to write a review.</p>
    <% } %>
  </section>
</section>
<%- include('../partials/footer') %>
