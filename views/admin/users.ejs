<%- include('../partials/admin-header') %>
<div class="admin-header">
  <h1>Users (<%= total %>)</h1>
</div>
<% if (typeof success !== 'undefined') { %><div class="alert alert-success"><%= success %></div><% } %>
<div style="margin-bottom: 1rem;">
  <form method="GET" style="display: flex; gap: 0.5rem;">
    <input type="text" name="search" placeholder="Search by name or email..." value="<%= search %>" style="padding: 0.5rem; border: 1px solid var(--border); border-radius: 6px; flex: 1;">
    <button type="submit" class="btn btn-primary">Search</button>
    <% if (search) { %><a href="/admin/users" class="btn btn-secondary">Clear</a><% } %>
  </form>
</div>
<table class="admin-table">
  <thead>
    <tr><th>Name</th><th>Email</th><th>Address</th><th>Phone</th><th>Orders</th><th>Total Spent</th><th>Role</th><th>Joined</th><th>Actions</th></tr>
  </thead>
  <tbody>
    <% users.forEach(u => { %>
      <tr>
        <td><strong><%= u.first_name %> <%= u.last_name %></strong></td>
        <td style="font-size: 0.85rem;"><%= u.email %></td>
        <td style="font-size: 0.8rem;"><%= u.city ? u.city + ', ' + u.country : '—' %></td>
        <td style="font-size: 0.8rem;"><%= u.phone || '—' %></td>
        <td><%= u.order_count || 0 %></td>
        <td>&euro;<%= Number(u.total_spent || 0).toFixed(2) %></td>
        <td><span class="badge <%= u.is_admin ? 'badge-paid' : 'badge-pending' %>"><%= u.is_admin ? 'Admin' : 'User' %></span></td>
        <td style="font-size: 0.8rem;"><%= new Date(u.created_at).toLocaleDateString() %></td>
        <td>
          <a href="/admin/users/edit/<%= u.id %>" class="btn btn-sm btn-primary">Edit</a>
          <form action="/admin/users/toggle-admin/<%= u.id %>" method="POST" style="display: inline;" onsubmit="return confirm('Toggle admin status for <%= u.first_name %>?')">
            <button type="submit" class="btn btn-sm <%= u.is_admin ? 'btn-danger' : 'btn-secondary' %>"><%= u.is_admin ? 'Demote' : 'Promote' %></button>
          </form>
        </td>
      </tr>
    <% }); %>
    <% if (users.length === 0) { %><tr><td colspan="9" style="text-align: center; padding: 2rem; color: var(--text-muted);">No users found</td></tr><% } %>
  </tbody>
</table>
<% if (totalPages > 1) { %><div class="pagination"><% for (let i = 1; i <= totalPages; i++) { %><a href="/admin/users?page=<%= i %><%= search ? '&search=' + search : '' %>" class="<%= page === i ? 'active' : '' %>"><%= i %></a><% } %></div><% } %>
<%- include('../partials/admin-footer') %>
