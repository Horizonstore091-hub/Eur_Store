<%- include('../partials/admin-header') %>
<div class="admin-header">
  <h1><%= page ? 'Edit' : 'New' %> Page</h1>
  <a href="/admin/pages" class="btn btn-secondary">← Back</a>
</div>
<form action="/admin/pages/<%= page ? 'edit/' + page.id : 'new' %>" method="POST" class="admin-form">
  <div class="form-group">
    <label>Page Title *</label>
    <input type="text" name="title" value="<%= page ? page.title : '' %>" required>
  </div>
  <div class="form-group">
    <label>Content</label>
    <textarea name="content" rows="15" style="font-family: monospace;"><%= page ? page.content : '' %></textarea>
  </div>
  <div class="form-group">
    <label>Meta Description</label>
    <input type="text" name="meta_description" value="<%= page ? page.meta_description : '' %>">
  </div>
  <div class="form-group">
    <label style="display: flex; align-items: center; gap: 0.5rem;">
      <input type="checkbox" name="is_active" value="1" <%= !page || page.is_active ? 'checked' : '' %>> Active
    </label>
  </div>
  <button type="submit" class="btn btn-primary btn-lg"><%= page ? 'Update' : 'Create' %> Page</button>
</form>
<%- include('../partials/admin-footer') %>
