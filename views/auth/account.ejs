<%- include('../partials/header') %>
<section class="container" style="padding: 2rem 0;">
  <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem;">My Account</h1>
  <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
    <div style="background: white; border: 1px solid var(--gray-200); border-radius: 10px; padding: 1.5rem;">
      <h3 style="margin-bottom: 1rem;">Profile Information</h3>
      <form action="/auth/account/update" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.3rem;">First Name</label>
            <input type="text" name="first_name" value="<%= user.first_name %>" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
          </div>
          <div class="form-group">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.3rem;">Last Name</label>
            <input type="text" name="last_name" value="<%= user.last_name %>" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
          </div>
        </div>
        <div class="form-group" style="margin-top: 0.5rem;">
          <label style="display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.3rem;">Address</label>
          <input type="text" name="address" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem;">
          <div class="form-group">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.3rem;">City</label>
            <input type="text" name="city" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
          </div>
          <div class="form-group">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.3rem;">Postal Code</label>
            <input type="text" name="postal_code" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
          </div>
        </div>
        <div class="form-group" style="margin-top: 0.5rem;">
          <label style="display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.3rem;">Country</label>
          <select name="country" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
            <option value="DE">Germany</option>
            <option value="AT">Austria</option>
            <option value="CH">Switzerland</option>
            <option value="FR">France</option>
            <option value="IT">Italy</option>
            <option value="ES">Spain</option>
            <option value="NL">Netherlands</option>
            <option value="BE">Belgium</option>
          </select>
        </div>
        <div class="form-group" style="margin-top: 0.5rem;">
          <label style="display: block; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.3rem;">Phone</label>
          <input type="tel" name="phone" style="width: 100%; padding: 0.5rem; border: 1px solid var(--gray-300); border-radius: 4px;">
        </div>
        <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">Update Profile</button>
      </form>
    </div>

    <div style="background: white; border: 1px solid var(--gray-200); border-radius: 10px; padding: 1.5rem;">
      <h3 style="margin-bottom: 1rem;">Recent Orders</h3>
      <% if (orders.length === 0) { %>
        <p style="color: var(--gray-500);">No orders yet.</p>
        <a href="/products" class="btn btn-outline" style="margin-top: 0.5rem;">Start Shopping</a>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 0.8rem;">
          <% orders.slice(0, 5).forEach(o => { %>
            <div style="border: 1px solid var(--gray-200); border-radius: 6px; padding: 0.8rem;">
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                  <strong style="font-size: 0.85rem;">#<%= o.order_number %></strong>
                  <div style="font-size: 0.8rem; color: var(--gray-500);">€<%= o.total.toFixed(2) %> · <%= new Date(o.created_at).toLocaleDateString() %></div>
                </div>
                <span class="badge badge-<%= o.status %>"><%= o.status %></span>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
