<%- include('../partials/header') %>
<section class="container" style="padding: 20px 0;">
  <h1 style="font-size: 1.3rem; font-weight: 400; margin-bottom: 20px;">My Account</h1>

  <% if (typeof success !== 'undefined') { %><div class="alert alert-success"><%= success %></div><% } %>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
    <div style="background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 20px;">
      <h2 style="font-size: 16px; font-weight: 700; margin-bottom: 10px;">Account Details</h2>
      <p style="font-size: 13px; color: var(--text-secondary);"><%= user.first_name %> <%= user.last_name %></p>
      <p style="font-size: 13px; color: var(--text-secondary);"><%= user.email %></p>
      <% if (user.is_admin) { %><a href="/admin" class="btn btn-sm btn-accent" style="margin-top: 6px;">Admin Dashboard</a><% } %>
      <a href="/auth/logout" class="btn btn-sm btn-secondary" style="margin-top: 6px;">Logout</a>
    </div>

    <div style="background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 20px;">
      <h2 style="font-size: 16px; font-weight: 700; margin-bottom: 10px;">Profile</h2>
      <form action="/auth/account/update" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px;">
          <input type="text" name="first_name" value="<%= user.first_name %>" style="padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 13px;" required>
          <input type="text" name="last_name" value="<%= user.last_name %>" style="padding: 6px; border: 1px solid var(--border); border-radius: 4px; font-size: 13px;" required>
        </div>
        <button type="submit" class="btn btn-sm btn-primary">Update Name</button>
      </form>
    </div>
  </div>

  <h2 style="font-size: 16px; font-weight: 700; margin-bottom: 12px;">Order History</h2>
  <% if (orders.length === 0) { %>
    <p style="color: var(--text-secondary); font-size: 13px;">No orders yet. <a href="/products">Start shopping</a></p>
  <% } else { %>
    <table class="admin-table">
      <thead>
        <tr><th>Order</th><th>Date</th><th>Total</th><th>Status</th><th>Payment</th></tr>
      </thead>
      <tbody>
        <% orders.forEach(o => { %>
          <tr>
            <td><a href="/checkout/confirmation/<%= o.order_number %>" style="color: var(--link);">#<%= o.order_number %></a></td>
            <td style="font-size: 12px;"><%= new Date(o.created_at).toLocaleDateString() %></td>
            <td>&euro;<%= o.total.toFixed(2) %></td>
            <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
            <td style="font-size: 12px;"><%= o.payment_method %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>
<%- include('../partials/footer') %>
