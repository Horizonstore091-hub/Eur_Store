<%- include('../partials/header') %>
<section class="container">
  <h1 style="font-size: 1.3rem; font-weight: 400; margin: 15px 0;">Checkout</h1>
  <% if (invalidStock) { %>
    <div class="alert alert-error">Some items in your cart are no longer available. <a href="/cart" style="color: inherit; font-weight: 700;">Update your cart</a></div>
  <% } else { %>
    <div class="checkout-page">
      <div>
        <form action="/checkout/place" method="POST" class="checkout-form">
          <h2>Shipping Address</h2>
          <div class="row-2">
            <div class="form-group">
              <label>First Name</label>
              <input type="text" name="first_name" value="<%= user.first_name %>" required>
            </div>
            <div class="form-group">
              <label>Last Name</label>
              <input type="text" name="last_name" value="<%= user.last_name %>" required>
            </div>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="<%= user.email %>" required>
          </div>
          <div class="form-group">
            <label>Phone</label>
            <input type="tel" name="phone" placeholder="+49 30 12345678">
          </div>
          <div class="form-group">
            <label>Address</label>
            <input type="text" name="address" placeholder="Street address" required>
          </div>
          <div class="row-2">
            <div class="form-group">
              <label>City</label>
              <input type="text" name="city" required>
            </div>
            <div class="form-group">
              <label>Postal Code</label>
              <input type="text" name="postal_code" required>
            </div>
          </div>
          <div class="form-group">
            <label>Country</label>
            <select name="country" required>
              <option value="DE">Germany</option>
              <option value="AT">Austria</option>
              <option value="BE">Belgium</option>
              <option value="BG">Bulgaria</option>
              <option value="HR">Croatia</option>
              <option value="CY">Cyprus</option>
              <option value="CZ">Czech Republic</option>
              <option value="DK">Denmark</option>
              <option value="EE">Estonia</option>
              <option value="FI">Finland</option>
              <option value="FR">France</option>
              <option value="GR">Greece</option>
              <option value="HU">Hungary</option>
              <option value="IS">Iceland</option>
              <option value="IE">Ireland</option>
              <option value="IT">Italy</option>
              <option value="LV">Latvia</option>
              <option value="LI">Liechtenstein</option>
              <option value="LT">Lithuania</option>
              <option value="LU">Luxembourg</option>
              <option value="MT">Malta</option>
              <option value="NL">Netherlands</option>
              <option value="NO">Norway</option>
              <option value="PL">Poland</option>
              <option value="PT">Portugal</option>
              <option value="RO">Romania</option>
              <option value="SK">Slovakia</option>
              <option value="SI">Slovenia</option>
              <option value="ES">Spain</option>
              <option value="SE">Sweden</option>
              <option value="CH">Switzerland</option>
              <option value="GB">United Kingdom</option>
            </select>
          </div>

          <h2>Payment Method</h2>
          <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 10px;">We accept cryptocurrency and digital gift cards</p>

          <div class="payment-methods">
            <label class="payment-method selected">
              <input type="radio" name="payment_method" value="crypto_btc" checked>
              <div>
                <div class="method-name">Bitcoin (BTC)</div>
                <div class="method-desc">Pay with Bitcoin &mdash; fast, secure, borderless</div>
              </div>
            </label>
            <label class="payment-method">
              <input type="radio" name="payment_method" value="crypto_eth">
              <div>
                <div class="method-name">Ethereum (ETH)</div>
                <div class="method-desc">Pay with Ethereum &mdash; smart contract secured</div>
              </div>
            </label>
            <label class="payment-method">
              <input type="radio" name="payment_method" value="crypto_usdt">
              <div>
                <div class="method-name">Tether (USDT)</div>
                <div class="method-desc">Stablecoin &mdash; value pegged to USD</div>
              </div>
            </label>
            <label class="payment-method">
              <input type="radio" name="payment_method" value="crypto_usdc">
              <div>
                <div class="method-name">USD Coin (USDC)</div>
                <div class="method-desc">Stablecoin &mdash; fully reserved</div>
              </div>
            </label>
            <label class="payment-method">
              <input type="radio" name="payment_method" value="gift_steam">
              <div>
                <div class="method-name">Steam Gift Card</div>
                <div class="method-desc">Pay using Steam wallet gift cards &mdash; enter code at checkout</div>
              </div>
            </label>
            <label class="payment-method">
              <input type="radio" name="payment_method" value="gift_razer">
              <div>
                <div class="method-name">Razer Gold Gift Card</div>
                <div class="method-desc">Pay using Razer Gold gift cards &mdash; enter code at checkout</div>
              </div>
            </label>
            <label class="payment-method">
              <input type="radio" name="payment_method" value="gift_apple">
              <div>
                <div class="method-name">Apple Gift Card</div>
                <div class="method-desc">Pay using Apple gift cards &mdash; enter code at checkout</div>
              </div>
            </label>
          </div>

          <p style="font-size: 12px; color: var(--text-secondary); margin: 8px 0;">After placing your order, you will receive payment instructions to complete your transfer.</p>

          <button type="submit" class="btn btn-primary btn-lg btn-block" style="margin-top: 12px;">Place Order &mdash; &euro;<%= total.toFixed(2) %></button>
        </form>
      </div>

      <div class="order-summary">
        <h3>Order Summary</h3>
        <% items.forEach(item => { %>
          <div class="item">
            <span><%= item.name %> x <%= item.quantity %></span>
            <span>&euro;<%= item.total.toFixed(2) %></span>
          </div>
        <% }); %>
        <div class="item" style="border-top: 1px solid var(--border); padding-top: 10px; margin-top: 6px;">
          <span>Subtotal</span><span>&euro;<%= subtotal.toFixed(2) %></span>
        </div>
        <div class="item">
          <span>Delivery</span><span><%= shippingCost === 0 ? 'FREE' : '&euro;' + shippingCost.toFixed(2) %></span>
        </div>
        <div class="item">
          <span>VAT (19%)</span><span>&euro;<%= tax.toFixed(2) %></span>
        </div>
        <div class="item" style="font-weight: 700; font-size: 1.1rem; border-top: 2px solid var(--border); padding-top: 10px; margin-top: 6px;">
          <span>Total</span><span>&euro;<%= total.toFixed(2) %></span>
        </div>
        <div style="margin-top: 16px; padding: 12px; background: var(--bg-light); border-radius: 4px; font-size: 12px; color: var(--text-secondary); line-height: 1.6;">
          <span class="icon-lock"></span> Secure checkout. We accept cryptocurrency and digital gift cards only.<br>
          <span class="icon-check"></span> Free returns within 30 days.<br>
          <span class="icon-truck"></span> Shipped from our EU warehouse.
        </div>
      </div>
    </div>
  <% } %>
</section>
<script>
document.querySelectorAll('.payment-method').forEach(el => {
  el.addEventListener('click', function() {
    document.querySelectorAll('.payment-method').forEach(e => e.classList.remove('selected'));
    this.classList.add('selected');
    this.querySelector('input[type="radio"]').checked = true;
  });
});
</script>
<%- include('../partials/footer') %>
