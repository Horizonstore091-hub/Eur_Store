<%- include('partials/header') %>
<section class="hero">
  <div class="container">
    <h1>Stay cool, save energy.</h1>
    <p>Premium cooling solutions for European homes and offices. Energy-efficient products rated A++ to A+++, CE certified, and built for the European climate.</p>
    <a href="/products" class="btn btn-prime">Shop the collection</a>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <h2>Shop by Category</h2>
      <p>Find exactly what you need to stay comfortable</p>
    </div>
    <div class="category-grid">
      <% const catImages = { 'air-conditioners': 'https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=300&h=300&fit=crop', 'tower-fans': 'https://images.unsplash.com/photo-1624898135772-0e4991a9d80c?w=300&h=300&fit=crop', 'pedestal-fans': 'https://images.unsplash.com/photo-1626806819282-2c1dc01a5e0c?w=300&h=300&fit=crop', 'desk-fans': 'https://images.unsplash.com/photo-1617201833818-6a0b4c4b6f5c?w=300&h=300&fit=crop', 'evaporative-coolers': 'https://images.unsplash.com/photo-1602523366596-7c5df2fe7323?w=300&h=300&fit=crop', 'ceiling-fans': 'https://images.unsplash.com/photo-1585128792020-5e9f3e0b1b8a?w=300&h=300&fit=crop', 'smart-cooling': 'https://images.unsplash.com/photo-1558002038-1055907df827?w=300&h=300&fit=crop', 'accessories': 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=300&h=300&fit=crop' }; %>
      <% categories.forEach(c => { %>
        <a href="/products?category=<%= c.slug %>" class="category-card">
          <div class="icon" style="background: var(--bg-light); border-radius: 8px; height: 120px; display: flex; align-items: center; justify-content: center; overflow: hidden; margin-bottom: 8px;">
            <img src="<%= catImages[c.slug] || 'https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=300&h=300&fit=crop' %>" alt="<%= c.name %>" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
          <h3><%= c.name %></h3>
          <p><%= c.description ? c.description.substring(0, 55) : 'Cooling solutions' %></p>
        </a>
      <% }); %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <h2>Featured Products</h2>
      <p>Top-rated cooling solutions for the European summer</p>
    </div>
    <div class="product-grid">
      <% featured.forEach(p => { %>
        <div class="product-card">
          <% if (p.compare_price && p.compare_price > p.price) { %><span class="badge">-<%= Math.round((1 - p.price/p.compare_price) * 100) %>%</span><% } %>
          <a href="/products/<%= p.slug %>" class="image">
            <img src="<%= p.image || '/images/placeholder.svg' %>" alt="<%= p.name %>">
          </a>
          <div class="category"><%= p.category_name || 'Cooling' %></div>
          <h3><a href="/products/<%= p.slug %>"><%= p.name %></a></h3>
          <div class="rating"><span class="icon-star"></span><span class="icon-star"></span><span class="icon-star"></span><span class="icon-star"></span><span class="icon-star-empty"></span></div>
          <div class="price">
            <span class="symbol">&euro;</span><%= Math.floor(p.price) %><span class="cents">.<%= (p.price % 1).toFixed(2).slice(2) %></span>
            <% if (p.compare_price && p.compare_price > p.price) { %><span class="compare-price">&euro;<%= p.compare_price.toFixed(2) %></span><span class="badge-save">Save &euro;<%= (p.compare_price - p.price).toFixed(2) %></span><% } %>
          </div>
          <% if (p.energy_rating) { %><span class="energy-badge"><%= p.energy_rating %></span><% } %>
          <div class="free-ship"><span class="icon-truck"></span> FREE delivery</div>
          <form action="/cart/add" method="POST" class="add-to-cart">
            <input type="hidden" name="product_id" value="<%= p.id %>">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn btn-primary btn-block">Add to Cart</button>
          </form>
        </div>
      <% }); %>
    </div>
    <div style="text-align: center; margin-top: 20px;">
      <a href="/products" class="btn btn-secondary btn-lg">View all products</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-title">
      <h2>Bestsellers</h2>
      <p>Europe's most popular cooling products this season</p>
    </div>
    <div class="product-grid">
      <% bestsellers.forEach(p => { %>
        <div class="product-card">
          <a href="/products/<%= p.slug %>" class="image">
            <img src="<%= p.image || '/images/placeholder.svg' %>" alt="<%= p.name %>">
          </a>
          <div class="category"><%= p.category_name || 'Cooling' %></div>
          <h3><a href="/products/<%= p.slug %>"><%= p.name %></a></h3>
          <div class="price">
            <span class="symbol">&euro;</span><%= Math.floor(p.price) %><span class="cents">.<%= (p.price % 1).toFixed(2).slice(2) %></span>
          </div>
          <div class="free-ship"><span class="icon-truck"></span> FREE delivery</div>
          <form action="/cart/add" method="POST" class="add-to-cart">
            <input type="hidden" name="product_id" value="<%= p.id %>">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="btn btn-primary btn-block">Add to Cart</button>
          </form>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<section style="background: var(--primary-light); color: #fff; padding: 30px 0; text-align: center;">
  <div class="container">
    <h2 style="font-size: 1.5rem; margin-bottom: 10px; font-weight: 400;">Made for the European Climate</h2>
    <p style="max-width: 700px; margin: 0 auto 16px; opacity: 0.85; font-size: 14px;">All our products meet EU energy efficiency standards, are CE certified, and designed for European electrical systems (220-240V, 50Hz).</p>
    <div class="trust-badges">
      <span>CE Certified</span>
      <span>Energy Class A+++</span>
      <span>EU Standards</span>
      <span>2-Year Warranty</span>
      <span>Free Shipping EU</span>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
